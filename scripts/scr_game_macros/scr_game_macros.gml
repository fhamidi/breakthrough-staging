// The first available level in the game.
#macro BEGIN_LEVEL rm_level_001

// The final available level in the game.
#macro FINAL_LEVEL rm_level_003

// The starting speed of the ball, in pixels per frame.
#macro BALL_START_SPEED 4

// The middle speed of the ball, in pixels per frame.
#macro BALL_MIDDLE_SPEED 8

// The top speed of the ball, in pixels per frame.
#macro BALL_TOP_SPEED 16